# HyruleLink server config. Copy to `.env` and fill in — the server auto-loads
# `.env` at startup (a real environment variable still overrides it). `.env` is
# git-ignored so your secrets never get committed.

# Global-admin secret. Unlocks the web "Admin key" box: delete any room, kick
# anyone, and manage found/owner in any room. Leave unset to disable global admin.
# Use a long random value, e.g.  python -c "import secrets;print(secrets.token_urlsafe(24))"
HYRULELINK_ADMIN_KEY=change-me-to-a-long-random-string

# Optional — auto-delete rooms idle this many days (default 14).
# HYRULELINK_ROOM_TTL_DAYS=14

# Optional — sqlite path (default server/hyrulelink.db).
# HYRULELINK_DB=server/hyrulelink.db
