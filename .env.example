# HyruleLink server config. Copy to `.env` and fill in — the server auto-loads
# `.env` at startup (a real environment variable still overrides it). `.env` is
# git-ignored so your secrets never get committed.

# ── Discord login (global admin) ─────────────────────────────────────────────
# Mods of your Discord server get admin rights (delete/kick/manage any room).
# You can reuse an existing Discord application; just add the redirect URL below
# to its OAuth2 → Redirects in the Discord Developer Portal.
DISCORD_CLIENT_ID=your-app-client-id
DISCORD_CLIENT_SECRET=your-app-client-secret
DISCORD_REDIRECT_URI=https://hyrulelink.billogna.lol/auth/callback
DISCORD_GUILD_ID=your-server-id
DISCORD_MOD_ROLE_IDS=roleid1,roleid2          # roles that count as admin
# DISCORD_ADMIN_USER_IDS=youruserid           # optional: user ids always admin
# At least 32 random characters; signs login/session tokens.
SESSION_SECRET=use-at-least-32-random-characters-here

# ── misc ─────────────────────────────────────────────────────────────────────
# HYRULELINK_ROOM_TTL_DAYS=14                  # auto-delete idle rooms (default 14)
# HYRULELINK_DB=server/hyrulelink.db           # sqlite path
